# Hadoop
CLUSTER_NAME=test

# Spark - Master
SPARK_MODE=master
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_HOME=/opt/spark
PYSPARK_PYTHON=/usr/bin/python3.11
PYSPARK_DRIVER_PYTHON=/usr/bin/python3.11

# Spark - Workers
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_PORT_1=7081
SPARK_WORKER_WEBUI_PORT_1=8081
SPARK_WORKER_PORT_2=7082
SPARK_WORKER_WEBUI_PORT_2=8082

# Source system ostgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=postgres

# Jobs - Clickstream Generator
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
CLICKSTREAM_TABLE=clickstream
BATCH_SIZE=100
INTERVAL_SECONDS=60
